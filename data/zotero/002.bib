@article{khadarWisdomCrowdCrowd2025,
  title = {Wisdom of the {{Crowd}}, {{Without}} the {{Crowd}}: {{A Socratic LLM}} for {{Asynchronous Deliberation}} on {{Perspectivist Data}}},
  shorttitle = {Wisdom of the {{Crowd}}, {{Without}} the {{Crowd}}},
  author = {Khadar, Malik and Runningen, Daniel and Tang, Julia and Chancellor, Stevie and Kaur, Harmanpreet},
  year = 2025,
  month = oct,
  journal = {Proceedings of the ACM on Human-Computer Interaction},
  volume = {9},
  number = {7},
  pages = {CSCW526:1--CSCW526:35},
  doi = {10.1145/3757707},
  urldate = {2026-06-10},
  abstract = {Data annotation underpins the success of modern AI, but the aggregation of crowd-collected datasets can harm the preservation of diverse perspectives in data. Difficult and ambiguous tasks cannot easily be collapsed into unitary labels. Prior work has shown that deliberation and discussion improve data quality and preserve diverse perspectives--however, synchronous deliberation through crowdsourcing platforms is time-intensive and costly. In this work, we create a Socratic dialog system using Large Language Models (LLMs) to act as a deliberation partner in place of other crowdworkers. Against a benchmark of synchronous deliberation on two tasks (Sarcasm and Relation detection), our Socratic LLM encouraged participants to consider alternate annotation perspectives, update their labels as needed (with higher confidence), and resulted in higher annotation accuracy (for the Relation task where ground truth is available). Qualitative findings show that our agent's Socratic approach was effective at encouraging reasoned arguments from our participants, and that the intervention was well-received. Our methodology lays the groundwork for building scalable systems that preserve individual perspectives in generating more representative datasets.},
  file = {/Users/edy/Zotero/storage/V956HHHP/Khadar 等 - 2025 - Wisdom of the Crowd, Without the Crowd A Socratic LLM for Asynchronous Deliberation on Perspectivis.pdf}
}

@inproceedings{mukhopadhyayExploringImpactProactive2026,
  title = {Exploring {{The Impact}} of {{Proactive Generative AI Agent Roles In Time-Sensitive Collaborative Problem-Solving Tasks}}},
  booktitle = {Proceedings of the 2026 {{CHI Conference}} on {{Human Factors}} in {{Computing Systems}}},
  author = {Mukhopadhyay, Anirban and Salubre, Kevin and Javed, Hifza and Mehrotra, Shashank and Akash, Kumar},
  year = 2026,
  month = apr,
  series = {{{CHI}} '26},
  pages = {1--25},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  doi = {10.1145/3772318.3791592},
  urldate = {2026-06-10},
  abstract = {Collaborative problem-solving under time pressure is common but difficult, as teams must generate ideas quickly, coordinate actions, and track progress. Generative AI offers new opportunities to assist, but we know little about how proactive agents affect the dynamics of real-time, co-located teamwork. We studied two forms of proactive support in digital escape rooms: a facilitator agent that offered summaries and group structures, and a peer agent that proposed ideas and answered queries. In a within-subjects study with 24 participants, we compared group performance and processes across three conditions: no AI, peer, and facilitator. Results show that the peer agent occasionally enhanced problem-solving by offering timely hints and memory support; however, it also disrupted flow, increased workload, and created over-reliance. In comparison, the facilitator agent provided light scaffolding but had a limited impact on outcomes. We provide design considerations for proactive generative AI agents based on our findings.},
  isbn = {979-8-4007-2278-3},
  file = {/Users/edy/Zotero/storage/K7K3SVQZ/Mukhopadhyay 等 - 2026 - Exploring The Impact of Proactive Generative AI Agent Roles In Time-Sensitive Collaborative Problem-.pdf}
}

