@inproceedings{zhangShallWeDig2026,
  title = {"{{Shall We Dig Deeper}}?": {{Designing}} and {{Evaluating Strategies}} for {{LLM Agents}} to {{Advance Knowledge Co-Construction}} in {{Asynchronous Online Discussions}}},
