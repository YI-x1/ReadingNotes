@article{khadarWisdomCrowdCrowd2025,
  title = {Wisdom of the {{Crowd}}, {{Without}} the {{Crowd}}: {{A Socratic LLM}} for {{Asynchronous Deliberation}} on {{Perspectivist Data}}},
