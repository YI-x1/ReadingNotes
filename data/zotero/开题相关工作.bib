  title = {Exploring {{How Older Adults Use}} a {{Smart Speaker}}–{{Based Voice Assistant}} in {{Their First Interactions}}: {{Qualitative Study}}},
  shorttitle = {Exploring {{How Older Adults Use}} a {{Smart Speaker}}–{{Based Voice Assistant}} in {{Their First Interactions}}},
  author = {Kim, Sunyoung},
  date = {2021-01-13},
