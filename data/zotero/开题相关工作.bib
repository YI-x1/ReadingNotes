@article{ojewaleMoreNotBetter2026,
  title = {More Is Not Better: {{Visual}} Uncertainty Cues and the Fragility of Trust Calibration in {{LLM-assisted}} Decision Making},
  shorttitle = {More Is Not Better},
  author = {Ojewale, Victor and Ryan, Julia and Venkatasubramanian, Suresh and Boykin, C. Malik},
  date = {2026-05-01},
  journaltitle = {Computers in Human Behavior: Artificial Humans},
  shortjournal = {Computers in Human Behavior: Artificial Humans},
